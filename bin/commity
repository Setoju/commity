#!/usr/bin/env ruby
# frozen_string_literal: true

require 'optparse'
require 'dotenv/load'
require 'commity'

options = {
  type: :commit,
  base_branch: 'main',
  no_copy: false,
  candidates: 1
}

OptionParser.new do |opts|
  opts.banner = <<~BANNER

    AI Commit — Powered by Ollama (llama3.2)
    Usage: commity [options]

  BANNER

  opts.on('--type TYPE', %i[commit pr], 'Message type: commit or pr (default: commit)') do |type|
    options[:type] = type
  end

  opts.on('--base BRANCH', 'Base branch for PR diff (default: main)') do |branch|
    options[:base_branch] = branch
  end

  opts.on('--no-copy', 'Print output only, skip clipboard copy') do
    options[:no_copy] = true
  end

  opts.on('--candidates N', Integer, 'Number of output candidates to generate (1-5, default: 1)') do |count|
    raise OptionParser::InvalidArgument, 'candidates must be between 1 and 5' unless count.between?(1, 5)

    options[:candidates] = count
  end

  opts.on('-h', '--help', 'Show this help') do
    puts opts
    exit
  end
end.parse!

begin
  flow = if options[:type] == :commit
           Commity::Flows::CommitFlow.new(options: options)
         else
           Commity::Flows::PrFlow.new(options: options)
         end

  flow.run
rescue RuntimeError => e
  puts "\nError: #{e.message}\n\n"
  exit 1
rescue SocketError, Errno::ECONNREFUSED
  puts "\nError: Could not connect to Ollama. Make sure it is running on localhost:11434.\n\n"
  exit 1
rescue Net::OpenTimeout, Net::ReadTimeout
  puts "\nError: Ollama request timed out while generating output. " \
       "Check that the model is loaded and Ollama is responsive.\n\n"
  exit 1
rescue StandardError => e
  puts "\nError: Something went wrong (#{e.class}).\n\n"
  exit 1
end
